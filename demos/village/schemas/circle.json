{
  "hyperschema": {
    "name": "Circle",
    "alg": 1,
    "body": {
      "op": "expand",
      "role": {
        "exact": "friend"
      },
      "schema": "Person",
      "in": {
        "op": "group",
        "key": "byTargetContext",
        "in": {
          "op": "select",
          "pred": {
            "hasPointer": {
              "targetEntity": {
                "var": "root"
              }
            }
          },
          "in": {
            "op": "mask",
            "policy": "drop",
            "in": "input"
          }
        }
      }
    }
  },
  "schema": {
    "props": {
      "name": {
        "pick": {
          "order": {
            "byTimestamp": "desc"
          }
        }
      },
      "follows": {
        "all": {
          "order": {
            "byTimestamp": "asc"
          }
        }
      }
    },
    "default": {
      "pick": {
        "order": {
          "byTimestamp": "desc"
        }
      }
    }
  },
  "roots": [
    "person:wren",
    "person:miles",
    "person:odile",
    "person:petra"
  ]
}

exports[`§21.7 pinning — the degenerate single-lens case is byte-identical > the single-lens SDL never moves 1`] = `
"type Query {
  """Resolve Plant at an entity. Absence is an answer, not an error."""
  plant(
    entity: ID!

    """
    Resolve against the ground as it stood at this moment (a millisecond timestamp). Omit to read the present. Erasure still wins: purged content never reappears (§11).
    """
    asOf: Float
  ): PlantView!
}

"""The Plant hyperschema, resolved under its registered policy."""
type PlantView {
  """The root entity this view is about."""
  _entity: ID!

  """The content address of the resolved view — the snapshot, the answer."""
  _hex: String!

  """
  The content address of the gathered hyperview — the evidence before any policy. Two lenses over the same body and root share it while their _hex may differ. On live streams, frames are emitted when the ANSWER moves — between frames the evidence may have grown without changing it; query for the current value.
  """
  _hviewHex: String!

  """The whole resolved view, dynamic properties included."""
  _view: ViewValue!

  """
  The time pin (SPEC §26): the moment T this view was resolved against, on an AS-OF read; null on a present-tense read (the live materialization by construction).
  """
  _asOf: Float

  """
  The erasure annotation (SPEC §26/§11): on an as-of read, the sorted timestamps at which this ground lawfully forgot something SINCE the moment T — each moment flags a discontinuity where this reconstruction of the past may be missing a since-erased fact (the content stays forgotten; only THAT and WHEN an erasure fell in the window is revealed; the count is the list's length). Null on a present read.
  """
  _forgotten: [Float!]
  height: ViewValue
  message: ViewValue
}

"""
A resolved view value — primitive, list, nested view, or a bytes envelope (§23.7).
"""
scalar ViewValue

type Mutation {
  """
  Claim properties of an entity under Plant: every provided argument becomes one signed delta. Returns the re-resolved view.
  """
  plant(entity: ID!, height: PrimitiveValue, message: PrimitiveValue): PlantView!

  """
  Retract YOUR OWN contributions to the named fields of a Plant entity — each falls to what survives, or to absence. Returns the re-resolved view.
  """
  clearPlant(entity: ID!, fields: [String!]!): PlantView!

  """
  Retract YOUR OWN contribution(s) of specific values to one field of a Plant entity — the rest of the field stands. Returns the re-resolved view.
  """
  removePlant(entity: ID!, field: String!, values: [PrimitiveValue!]!): PlantView!

  """
  Emit one signed delta from an explicit pointer list — the general form every template is sugar for. Each pointer is entity (at + context) or primitive (value).
  """
  _claim(pointers: [PointerInput!]!): ClaimReceipt!
}

"""A claimable value: string, number, or boolean."""
scalar PrimitiveValue

"""The signed delta a claim landed as."""
type ClaimReceipt {
  delta: ID!
}

input PointerInput {
  role: String!

  """entity pointer target id (wants context too)"""
  at: ID
  context: String
  value: PrimitiveValue
}

type Subscription {
  """Hold Plant live at an entity: a snapshot, then patches."""
  plant(entity: ID!): PlantPatch!
}

"""A live Plant view: an initial snapshot, then one patch per change."""
type PlantPatch {
  """The root entity this view is about."""
  _entity: ID!

  """The content address of the resolved view — the snapshot, the answer."""
  _hex: String!

  """
  The content address of the gathered hyperview — the evidence before any policy. Two lenses over the same body and root share it while their _hex may differ. On live streams, frames are emitted when the ANSWER moves — between frames the evidence may have grown without changing it; query for the current value.
  """
  _hviewHex: String!

  """The whole resolved view, dynamic properties included."""
  _view: ViewValue!

  """
  The time pin (SPEC §26): the moment T this view was resolved against, on an AS-OF read; null on a present-tense read (the live materialization by construction).
  """
  _asOf: Float

  """
  The erasure annotation (SPEC §26/§11): on an as-of read, the sorted timestamps at which this ground lawfully forgot something SINCE the moment T — each moment flags a discontinuity where this reconstruction of the past may be missing a since-erased fact (the content stays forgotten; only THAT and WHEN an erasure fell in the window is revealed; the count is the list's length). Null on a present read.
  """
  _forgotten: [Float!]
  height: ViewValue
  message: ViewValue

  """The prior snapshot's content address; null on the initial snapshot."""
  _fromHex: String

  """The properties this patch moved; null on the initial snapshot."""
  _changed: [String!]
}"
`;
